# Lanyard connection
LANYARD_URL=http://localhost:3000
LANYARD_ADMIN_API_KEY=

# Dashboard OIDC client (auto-registered with Lanyard on first boot)
DASHBOARD_CLIENT_ID=dashboard
DASHBOARD_CLIENT_SECRET=
DASHBOARD_URL=http://localhost:4000

# Session encryption key (32+ characters)
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# Server
PORT=4000
NODE_ENV=development
